# =============================================================
# LOCAL DEV ONLY — gitignored, never commit this file.
# Rotate any value you've shared outside this file.
# Copy these same keys into Vercel's project env vars for prod
# (https://vercel.com/<you>/<project>/settings/environment-variables).
# =============================================================

# Where the in-store TV QR code points. Local dev = Vite's port.
VITE_PUBLIC_URL=http://localhost:5173

# Region. Use "sandbox" for testing without real charges; flip to
# "us" when you're ready to take live orders. NOTE: the API token
# is region-specific — a sandbox token won't work in `us` and vice
# versa. If you mint a sandbox token, swap it in alongside region=sandbox.
CLOVER_REGION=us

# Clover merchant + API credentials (from your message).
CLOVER_MERCHANT_ID=1ETEE6B1ZDA2G
CLOVER_API_TOKEN=6b8483ad-f9da-6dba-9d71-2bc160c61c67
# Client-side mirror of the merchant id, used by the Google Pay
# tokenizationSpecification on the checkout page. Safe to expose.
VITE_CLOVER_MERCHANT_ID=1ETEE6B1ZDA2G

# Clover Ecommerce keys.
CLOVER_ECOMM_PRIVATE_KEY=a4b7a1f0-6571-ffff-6fe8-f76820165b03
# Client-side mirror of the PUBLIC key. Clover.js on /checkout tokenizes
# cards using this; expose it to the browser via the VITE_ prefix. Get
# the value from Clover Dashboard → Setup → Payments → Ecommerce Keys.
# PUBLIC keys are safe to ship — they only authorize tokenization, not
# charges. Charges still require the SECRET key on the server.
# REQUIRED for the Decision A inline-charge flow; without it, /checkout
# will throw "VITE_CLOVER_ECOMM_PUBLIC_KEY is not set".
VITE_CLOVER_ECOMM_PUBLIC_KEY=

# Webhook signing secret. Only needed if you re-enable the
# /api/clover/hosted-checkout-webhook endpoint. Decision A doesn't use
# it. Leave blank.
CLOVER_WEBHOOK_SECRET=

# Set to "false" (or remove the line) to hit real Clover.
# Leave at "true" if you want to keep using the mock menu/orders for UI work.
USE_MOCK_CLOVER=false

# HTTPS base URL used by /api/orders/create when building the redirect
# URLs Clover Hosted Checkout requires. Clover REJECTS http URLs even
# in sandbox, so for local testing you need one of:
#
#   1. Set this to an ngrok HTTPS tunnel:
#        npx ngrok http 3000        # then copy the https URL
#      CHECKOUT_BASE_URL=https://abc123.ngrok-free.app
#
#   2. Set this to your Vercel preview URL after `vercel deploy`:
#      CHECKOUT_BASE_URL=https://yolo-rollo-ordering-git-main-you.vercel.app
#
# On the production deployment, leave this UNSET — the API derives the
# URL from the request, which is already HTTPS on Vercel.
CHECKOUT_BASE_URL=
